generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum VehicleCondition {
  NEW
  LIKE_NEW
  EXCELLENT
  GOOD
  FAIR
  POOR
  SALVAGE
}

enum VehicleType {
  SEDAN
  SUV
  TRUCK
  VAN
  RV
  CONVERTIBLE
}

enum FuelType {
  GASOLINE
  DIESEL
  ELECTRIC
  HYBRID
  PHEV
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

model Vehicle {
  id           String       @id @default(uuid())
  make         String 
  model        String
  year         Int
  price        Decimal 
  quantity     Int          @default(1)
  mileage      Int
  bodyType     VehicleType
  fuelType     FuelType
  transmission Transmission
  description  String? 
  features     String[] 
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  vin       String           @unique @db.VarChar(17)
  condition VehicleCondition

  @@index([price]) 
  @@index([bodyType]) 
  @@map("vehicles")
}
