# =============================================================================
#  Neon Serverless PostgreSQL — Connection Strings
#  !! Never commit this file. It is listed in .gitignore. !!
# =============================================================================

# ── Pooled connection (PgBouncer) ─────────────────────────────────────────────
# Used by your application at runtime.
# Format:  postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true&sslmode=require
# Neon console → Project → Connection Details → select "Pooled connection"
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-xxxx.region.aws.neon.tech:6543/neondb?pgbouncer=true&sslmode=require"

# ── Direct connection ─────────────────────────────────────────────────────────
# Used exclusively by Prisma CLI (db push / migrate / generate).
# Format:  postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# Neon console → Project → Connection Details → deselect "Pooled connection"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx-xxxx.region.aws.neon.tech:5432/neondb?sslmode=require"
